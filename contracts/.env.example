# ─────────────────────────────────────────────────────────────
#  EcoWatt Contracts — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Deployer private key (no 0x prefix needed for some tools, include it here)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Alchemy API key (get one free at https://www.alchemy.com)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Block explorer API keys for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
ARBISCAN_API_KEY=your_arbiscan_api_key_here
BASESCAN_API_KEY=your_basescan_api_key_here

# Set to "true" to enable gas cost reporting during tests
REPORT_GAS=false

# Deployed contract addresses (filled in after running deploy script)
ECOW_TOKEN_ADDRESS=
MARKETPLACE_ADDRESS=
STAKING_ADDRESS=
